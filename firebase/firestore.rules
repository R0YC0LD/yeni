rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı Fonksiyonlar
    function isSignedIn() { return request.auth != null; }
    function getUserRole() { 
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'user'; 
    }
    function isAdmin() { return getUserRole() == 'admin'; }
    function isProducer() { return getUserRole() == 'producer'; }
    function isArtist() { return getUserRole() == 'artist'; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(uid) && (
        !('isApproved' in request.resource.data) || request.resource.data.isApproved == false
      );
      allow update: if isSignedIn() && (
        (isOwner(uid) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'role', 'banned', 'banReason', 'suspendedUntil', 'suspendReason']))) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAdmin();
      allow update, delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /demos/{demoId} {
      // Demolar prodüktörlerin kendi içinde puanladığı üretim havuzu: sadece admin/prodüktör
      // ve demonun sahibi okuyabilir, başka bir sanatçı/kullanıcı tüm demoları listeleyemez.
      allow read: if isSignedIn() && (isAdmin() || isProducer() || isOwner(resource.data.ownerId));
      // Sanatçı sadece kendi demosunu ekleyebilir; puanlama (update) admin/prodüktöre özel kalır.
      allow create: if isSignedIn() && (isAdmin() || isProducer() || (isArtist() && isOwner(request.resource.data.ownerId)));
      allow update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /releases/{releaseId} {
      // Yayın bekleyen/yayınlanmamış şarkılar sadece admin ve sahibi tarafından okunabilir
      // (yayın öncesi sızıntıyı önlemek için diğer kullanıcılara kapalı).
      allow read: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
      allow create: if isSignedIn() && (isAdmin() || isArtist() || isProducer());
      // Admin her alanı güncelleyebilir (onay/red/not/otomatik yayın alanları dahil).
      // Sahibi ise SADECE reddedilen kendi yayınını "düzelt ve yeniden gönder" akışında,
      // sadece belirli alanları değiştirip durumu yeniden 'bekliyor'a çekebilir; admin'in
      // verdiği adminNote/reviewedAt/reviewedBy/ownerId/createdAt alanlarına dokunamaz.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          isOwner(resource.data.ownerId) &&
          resource.data.status == 'reddedildi' &&
          request.resource.data.status == 'bekliyor' &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['status', 'title', 'artistName', 'lyrics', 'coverUrl', 'audioUrl', 'isExplicit', 'releaseDate', 'resubmittedAt']
          )
        )
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    match /beats/{beatId} {
      // Mutfak (beat/preset/stem) sadece prodüktör ve admin için: sanatçılar göremez.
      allow read: if isSignedIn() && (isAdmin() || isProducer());
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /presets/{presetId} {
      allow read: if isSignedIn() && (isAdmin() || isProducer());
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /stems/{stemId} {
      allow read: if isSignedIn() && (isAdmin() || isProducer());
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /notifications/{uid}/user_notifications/{docId} {
      allow read, delete: if isSignedIn() && isOwner(uid);
      allow create, update: if isSignedIn();
    }
    
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        chatId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && request.auth.uid in resource.data.participants) ||
        (request.resource != null && request.auth.uid in request.resource.data.participants)
      );
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        chatId.matches('.*' + request.auth.uid + '.*') ||
        (get(/databases/$(database)/documents/chats/$(chatId)).data != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
      );
    }
    
    match /tasks/{uid}/assigned/{taskId} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create, update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && (isOwner(uid) || isAdmin());
    }

    match /activity_log/{logId} {
      allow read: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
