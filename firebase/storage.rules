rules_version = '2';

// MüzikHan - Firebase Storage Security Rules
// Bu kurallar sadece yetkili kullanıcıların işlem yapmasını sağlar ve kötü niyetli spamleri önler.

service firebase.storage {
  match /b/{bucket}/o {

    // Yardımcı fonksiyonlar
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') && request.resource.size < 5 * 1024 * 1024; // Maksimum 5MB
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*') && request.resource.size < 50 * 1024 * 1024; // Maksimum 50MB
    }

    function isUnderSize(maxMB) {
      return request.resource.size < maxMB * 1024 * 1024;
    }

    // Mutfak (beat/preset/stem) sadece prodüktör/admin: Firestore'daki kullanıcı rolüne bakıyoruz.
    function callerRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }
    function isProducerOrAdmin() {
      return callerRole() == 'producer' || callerRole() == 'admin';
    }

    // Profil Fotoğrafları
    // Okuma: Herkese açık (Kullanıcılar birbirini görebilsin diye)
    // Yazma/Silme: Sadece kendi klasörüne resim yükleyebilir.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write, delete: if isAuth() && isOwner(userId) && (request.resource == null || isValidImage());
    }

    // Demolar (Şarkılar)
    // Okuma: Sisteme giriş yapmış herkes dinleyebilir.
    // Yazma/Silme: Sadece kendi klasörüne yükleyebilir, sadece MP3/WAV vb. ses dosyası olmalı.
    match /demos/{userId}/{fileName} {
      allow read: if isAuth();
      allow write, delete: if isAuth() && isOwner(userId) && (request.resource == null || isValidAudio());
    }

    // Yayın Kapak Fotoğrafları
    // Okuma: Sisteme giriş yapmış herkes görebilir.
    // Yazma/Silme: Sadece kendi klasörüne resim yükleyebilir.
    match /releases_covers/{userId}/{fileName} {
      allow read: if isAuth();
      allow write, delete: if isAuth() && isOwner(userId) && (request.resource == null || isValidImage());
    }

    // Yayın Ses Dosyaları
    // Okuma: Sisteme giriş yapmış herkes (veya adminler) dinleyebilir.
    // Yazma/Silme: Sadece kendi klasörüne yükleyebilir.
    match /releases_audio/{userId}/{fileName} {
      allow read: if isAuth();
      allow write, delete: if isAuth() && isOwner(userId) && (request.resource == null || isValidAudio());
    }

    // Mutfak: Beat Dosyaları (ses) - sadece prodüktör/admin
    match /beats/{userId}/{fileName} {
      allow read: if isAuth() && isProducerOrAdmin();
      allow write, delete: if isAuth() && isOwner(userId) && isProducerOrAdmin() && (request.resource == null || isUnderSize(50));
    }

    // Mutfak: Preset Dosyaları (DAW preset, herhangi bir format olabilir) - sadece prodüktör/admin
    match /presets/{userId}/{fileName} {
      allow read: if isAuth() && isProducerOrAdmin();
      allow write, delete: if isAuth() && isOwner(userId) && isProducerOrAdmin() && (request.resource == null || isUnderSize(50));
    }

    // Mutfak: Stem Dosyaları (.zip/.rar) - sadece prodüktör/admin
    match /stems/{userId}/{fileName} {
      allow read: if isAuth() && isProducerOrAdmin();
      allow write, delete: if isAuth() && isOwner(userId) && isProducerOrAdmin() && (request.resource == null || isUnderSize(100));
    }

    // Diğer her şey için varsayılan olarak kapalı
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
